meta {
  name: 200-Empty-Eis-Results-Date-Eori
  type: http
  seq: 8
}

post {
  url: http://localhost:9071/cau/validatecustomsauth/v1
  body: json
  auth: bearer
}

auth:bearer {
  token: {{bearerToken}}
}

body:json {
  {
    "validityDate": "{{date}}",
    "authType": "UKNW",
    "eoris" : ["GB999999999999603"]
  }
}

assert {
  res.status: eq 200
  res.body.authType: eq "UKNW"
  res.body.processingDate: isUndefined
  res.body.results: isUndefined
}
