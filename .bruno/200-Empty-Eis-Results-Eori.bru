meta {
  name: 200-Empty-Eis-Results-Eori
  type: http
  seq: 9
}

post {
  url: http://localhost:9071/cau/validatecustomsauth/v1
  body: json
  auth: bearer
}

auth:bearer {
  token: {{bearerToken}}
}

body:json {
  {
    "validityDate": "{{date}}",
    "authType": "UKNW",
    "eoris" : ["GB999999999999602"]
  }
}

assert {
  res.status: eq 200
  res.body.authType: eq "UKNW"
  res.body.results: isUndefined
}

tests {
  test("confirm Date Format", function() {
     var currentDate = new Date();
      currentDate
      .setUTCHours(0,0,0,0);
     var timestamp = 
  currentDate.toISOString().replace(".000", '.00');
    const data = res.getBody();
  expect(res.body.processingDate).to.equal(timestamp);
  });
}
