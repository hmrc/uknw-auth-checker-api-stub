meta {
  name: 200-Empty-Eis-Response-Eori
  type: http
  seq: 10
}

post {
  url: http://localhost:9071/cau/validatecustomsauth/v1
  body: json
  auth: bearer
}

auth:bearer {
  token: {{bearerToken}}
}

body:json {
  {
    "validityDate": "{{date}}",
    "authType": "UKNW",
    "eoris" : ["GB999999999999601"]
  }
}

assert {
  res.status: eq 200
  res.body: isEmpty
}
